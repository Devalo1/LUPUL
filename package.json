{
  "name": "my-typescript-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "dependencies": {
    "cors": "^2.8.5",
    "firebase": "^11.6.0",
    "firebase-admin": "^13.2.0",
    "firebase-functions": "^6.3.2",
    "framer-motion": "^10.18.0",
    "nodemailer": "^6.10.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0",
    "react-router-dom": "^6.11.2",
    "web-vitals": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.10",
    "@types/connect": "^3.4.38",
    "@types/http-errors": "^2.0.4",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.39",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^9.1.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "postcss": "^8.4.31",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.3.3",
    "vite": "^6.2.5"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc && vite build",
    "test": "vitest",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "security-fix": "node scripts/security-fix.js",
    "fix-dependencies": "node scripts/fix-dependencies.js",
    "check-deps": "node scripts/check-dependencies.js",
    "clean": "rimraf node_modules dist",
    "dev": "vite",
    "serve": "vite preview",
    "emulators": "firebase emulators:start",
    "dev:all": "concurrently \"npm run dev\" \"npm run emulators\"",
    "check-emulators": "node scripts/check-emulators.js"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "firebaseAuth": {
    "import": [
      "import { getAuth, onAuthStateChanged } from 'firebase/auth';"
    ],
    "authLogic": [
      "const auth = getAuth();",
      "onAuthStateChanged(auth, (user) => {",
      "  if (user) {",
      "    console.log('User is signed in:', user);",
      "  } else {",
      "    console.log('No user is signed in.');",
      "  }",
      "});"
    ]
  }
}
